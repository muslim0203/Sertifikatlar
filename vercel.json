{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "api/status.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "api/webhook.py" },
    { "src": "/api/status", "dest": "api/status.py" },
    { "src": "/", "dest": "api/index.py" }
  ]
}
